# ──────────────────────────────────────────────────────────────────────────
# swimlanes — environment config
# Copy to .env.local:  cp .env.example .env.local
# .env.local is gitignored and is the ONLY place tokens may live.
# ──────────────────────────────────────────────────────────────────────────

# Simulation mode. When true (the default), ALL lanes resolve through the
# MockProvider against the committed fixtures — no network, no tokens needed.
# A fresh clone runs end-to-end offline with SIMULATE=true.
# Set to false to use the real GitLab/GitHub providers (requires tokens below).
SIMULATE=true

# ──────────────────────────────────────────────────────────────────────────
# Live provider tokens — only used when SIMULATE=false.
# These are placeholders. Replace with your own; never commit real values.
# ──────────────────────────────────────────────────────────────────────────

# GitLab Personal Access Token, scope: read_api
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitHub fine-grained Personal Access Token (read-only: Issues + Metadata)
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
